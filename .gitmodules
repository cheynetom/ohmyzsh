[submodule "custom/plugins/zsh-completion-generator"]
	path = custom/plugins/zsh-completion-generator
	url = https://github.com/RobSis/zsh-completion-generator
[submodule "custom/plugins/zsh-autosuggestions"]
	path = custom/plugins/zsh-autosuggestions
